{
  "name": "chromaflow",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "ChromaFlow — ein Farbverlauf-Puzzle als Web-App (inspiriert von Farbsortier-Spielen wie I Love Hue, komplett eigenständige Umsetzung).",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173 --strictPort",
    "e2e:server": "npm run build && npm run preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "icons": "node scripts/gen-icons.mjs",
    "shots": "node scripts/shots.mjs"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "chroma-js": "^3.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/chroma-js": "^3.1.2",
    "@types/node": "^26.1.0",
    "pngjs": "^7.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
